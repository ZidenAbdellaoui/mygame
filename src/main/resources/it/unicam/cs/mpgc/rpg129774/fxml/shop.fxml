<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane styleClass="menu-root" xmlns:fx="http://javafx.com/fxml" fx:controller="it.unicam.cs.mpgc.rpg129774.ui.controller.ShopController">
    <top>
        <VBox alignment="CENTER" spacing="10">
            <Label text="Town Shop" styleClass="title-label"/>
            <Label fx:id="goldLabel" styleClass="subtitle-label"/>
        </VBox>
    </top>
    
    <center>
        <HBox alignment="CENTER" spacing="40">
            <!-- Shop Side -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="Shop Catalog" styleClass="subtitle-label"/>
                <ListView fx:id="shopList" prefHeight="300" prefWidth="350"/>
                <Label fx:id="detailLabel" styleClass="desc-label" wrapText="true" maxWidth="340" textAlignment="CENTER" prefHeight="80"/>
                <HBox alignment="CENTER" spacing="10">
                    <Button text="Buy Item" onAction="#onBuy" styleClass="action-btn, primary-btn"/>
                    <Button text="Buy 5x Potion" onAction="#onBuyFive" styleClass="action-btn, primary-btn"/>
                </HBox>
            </VBox>

            <!-- Inventory Side -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="Your Inventory" styleClass="subtitle-label"/>
                <ListView fx:id="inventoryListView" prefHeight="300" prefWidth="350"/>
                <Button text="Leave Shop" onAction="#onBack" styleClass="sys-btn"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
