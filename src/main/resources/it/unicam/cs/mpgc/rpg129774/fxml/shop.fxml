<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane styleClass="menu-root" xmlns:fx="http://javafx.com/fxml" fx:controller="it.unicam.cs.mpgc.rpg129774.ui.controller.ShopController">
    <top>
        <VBox alignment="CENTER" spacing="10">
            <Label text="Town Shop" styleClass="title-label"/>
            <Label fx:id="goldLabel" styleClass="subtitle-label"/>
        </VBox>
    </top>
    
    <center>
        <VBox alignment="CENTER" spacing="20">
            <ListView fx:id="shopList" prefHeight="300" prefWidth="500"/>
            <Label fx:id="detailLabel" styleClass="desc-label" wrapText="true" maxWidth="480" textAlignment="CENTER"/>
            
            <HBox alignment="CENTER" spacing="20">
                <Button text="Buy Item" onAction="#onBuy" styleClass="action-btn, primary-btn"/>
                <Button text="Buy 5x Potion" onAction="#onBuyFive" styleClass="action-btn, primary-btn"/>
                <Button text="Leave Shop" onAction="#onBack" styleClass="sys-btn"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
